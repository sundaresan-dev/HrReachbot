# ─── HRReach Bot Environment Variables ───
# Copy this file to .env and fill in your values.

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Admin Telegram User ID (only this user can access the bot)
ADMIN_ID=your_telegram_user_id_here

# Gmail address used to send emails
EMAIL=your_email@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
APP_PASSWORD=your_app_password_here

# Brevo API Key (for sending emails on Railway/Render)
# Sign up at: https://brevo.com
BREVO_API_KEY=your_brevo_api_key_here

# Flask server port (Railway sets this automatically)
PORT=5000
